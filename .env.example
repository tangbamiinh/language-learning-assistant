# Language Learning Assistant - Environment Variables
#
# Setup:
#   1. cp .env.example .env
#   2. Add your OPENROUTER_API_KEY below
#   3. make dev        (Phase 1: web + backend)
#   4. make docker-up  (Phase 2: LiveKit voice agent)

# ============================================================
# LLM Provider (required)
# ============================================================
# Qwen/Qwen3.5-9B via OpenRouter for VN+ZH bilingual performance
# Get your key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# ============================================================
# Bridge Server (Phase 1)
# ============================================================
# Port for the FastAPI bridge server (default: 8000)
PYTHON_API_PORT=8000

# ============================================================
# Speech-to-Text (Qwen3-ASR-1.7B - local, no key needed)
# ============================================================
# Local: pip install qwen-asr (no API key needed, runs on GPU)
# Cloud alternatives:
DASHSCOPE_API_KEY=sk-xxxxx     # Alibaba DashScope API for Qwen3-ASR

# ============================================================
# Text-to-Speech (local, no key needed)
# ============================================================
# Chinese TTS: Qwen3-TTS-12Hz-1.7B-Base (pip install qwen-tts)
# Vietnamese TTS: VieNeu-TTS (pip install vieneu)

# ============================================================
# LiveKit (Phase 2 - real-time voice)
# ============================================================
# ─── Option A: Self-hosted (recommended for development) ────
# Run: make docker-up
# The docker-compose.yml overrides these with the self-hosted values:
LIVEKIT_URL=ws://localhost:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=secret

# ─── Option B: LiveKit Cloud ────────────────────────────────
# Uncomment and replace with your cloud credentials:
# LIVEKIT_URL=wss://your-project.livekit.cloud
# LIVEKIT_API_KEY=your-api-key
# LIVEKIT_API_SECRET=your-api-secret

# ============================================================
# Hugging Face (for model downloads)
# ============================================================
# Optional: Speed up model downloads with a token
HUGGING_FACE_HUB_TOKEN=hf_xxxxx

# ============================================================
# Web App (Next.js frontend)
# ============================================================
# URL of the Python backend server (default: http://localhost:8000)
PYTHON_API_URL=http://localhost:8000
